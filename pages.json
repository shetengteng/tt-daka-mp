{
	"easycom": {
		"autoscan": true,
		"custom": {
			"^Tt(.*)": "@/components/Tt$1.vue"
		}
	},
	"pages": [
		{
			"path": "pages/index/index",
			"style": {
				"navigationStyle": "custom",
				"enablePullDownRefresh": true
			}
		}
	],
	"subPackages": [
		{
			"root": "pages/calendar",
			"pages": [
				{
					"path": "index",
					"style": {
						"navigationStyle": "custom",
						"enablePullDownRefresh": false
					}
				}
			]
		},
		{
			"root": "pages/stats",
			"pages": [
				{
					"path": "index",
					"style": {
						"navigationStyle": "custom",
						"enablePullDownRefresh": true
					}
				}
			]
		},
	{
		"root": "pages/mine",
		"pages": [
			{
				"path": "index",
				"style": {
					"navigationStyle": "custom",
					"enablePullDownRefresh": false
				}
			},
			{
				"path": "sub/disclaimer/index",
				"style": {
					"navigationBarTitleText": "免责声明"
				}
			}
		]
	},
		{
			"root": "pages/project",
			"pages": [
				{
					"path": "index",
					"style": {
						"navigationBarTitleText": "打卡项目管理"
					}
				},
				{
					"path": "sub/add/index",
					"style": {
						"navigationBarTitleText": "新建打卡"
					}
				},
			{
				"path": "sub/detail/index",
				"style": {
					"navigationBarTitleText": ""
				}
			},
				{
					"path": "sub/archived/index",
					"style": {
						"navigationBarTitleText": "已归档项目"
					}
				}
			]
		}
	],
	"globalStyle": {
		"navigationBarTextStyle": "black",
		"navigationBarTitleText": "DaKa",
		"navigationBarBackgroundColor": "#ffffff",
		"backgroundColor": "#ffffff"
	},
	"preloadRule": {
		"pages/index/index": {
			"network": "all",
			"packages": ["pages/calendar", "pages/stats", "pages/mine", "pages/project"]
		}
	},
	"uniIdRouter": {}
}
