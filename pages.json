{
	"easycom": {
		"autoscan": true,
		"custom": {
			"^Tt(.*)": "@/components/Tt$1.vue"
		}
	},
	"pages": [
		{
			"path": "pages/index/index",
			"style": {
				"navigationStyle": "custom",
				"enablePullDownRefresh": true
			}
		},
		{
			"path": "pages/calendar/index",
			"style": {
				"navigationStyle": "custom",
				"enablePullDownRefresh": false
			}
		},
		{
			"path": "pages/stats/index",
			"style": {
				"navigationStyle": "custom",
				"enablePullDownRefresh": true
			}
		},
		{
			"path": "pages/mine/index",
			"style": {
				"navigationStyle": "custom",
				"enablePullDownRefresh": false
			}
		},
		{
			"path": "pages/mine/sub/privacy/index",
			"style": {
				"navigationBarTitleText": "隐私政策"
			}
		},
		{
			"path": "pages/project/index",
			"style": {
				"navigationBarTitleText": "打卡项目管理"
			}
		},
		{
			"path": "pages/project/sub/add/index",
			"style": {
				"navigationBarTitleText": "新建打卡"
			}
		},
		{
			"path": "pages/project/sub/detail/index",
			"style": {
				"navigationBarTitleText": ""
			}
		},
		{
			"path": "pages/project/sub/archived/index",
			"style": {
				"navigationBarTitleText": "已归档项目"
			}
		}
	],
	"globalStyle": {
		"navigationBarTextStyle": "black",
		"navigationBarTitleText": "DaKa",
		"navigationBarBackgroundColor": "#ffffff",
		"backgroundColor": "#ffffff"
	},
	"uniIdRouter": {}
}
